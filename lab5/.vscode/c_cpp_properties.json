{
    "configurations": [
        {
            "name": "Lab5 (QEMU)",
            "includePath": [
                "${workspaceFolder}/include",
                "${workspaceFolder}/src"
            ],
            "defines": [
                "PLATFORM_QEMU"
            ],
            "compilerPath": "/usr/bin/riscv64-unknown-elf-gcc",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64",
            "compilerArgs": [
                "-mcmodel=medany",
                "-ffreestanding",
                "-nostdlib",
                "-fPIE",
                "-I",
                "${workspaceFolder}/include"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/include",
                    "${workspaceFolder}/src"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}
